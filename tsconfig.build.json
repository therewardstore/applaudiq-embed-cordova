{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": false,
    "declaration": true,
    "outDir": "lib",
    "rootDir": "src",
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020"
  },
  "include": ["src"],
  "exclude": ["node_modules", "**/__tests__/**", "**/*.test.*"]
}
